# RPC endpoints (testnet only)
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# Base Sepolia: live DIA push oracle (0x9bb71344...) + canonical v4 PoolManager. Used by the DIA fork test.
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Deployer (NEVER commit .env — copy this file only)
# With or without 0x prefix (script normalizes). Use a throwaway testnet wallet.
PRIVATE_KEY=

# Etherscan.io API (free: 5 calls/sec, 100k/day) for Ethereum Sepolia verification
ETHERSCAN_API_KEY=

# Blockscout REST key (blockscout-core-api tab) — NOT etherscan.io
# https://unichain-sepolia.blockscout.com/api-docs?tab=rest_api#blockscout-core-api
UNICHAIN_ETHERSCAN_API_KEY=

# Blockscout endpoints (./script/env-setup.sh blockscout-sync)
BLOCKSCOUT_CORE_API_URL=https://unichain-sepolia.blockscout.com/api
BLOCKSCOUT_ETH_RPC_URL=https://unichain-sepolia.blockscout.com/api/eth-rpc
BLOCKSCOUT_PRO_JSON_RPC_URL=https://api.blockscout.com/1301/json-rpc
UNICHAIN_CHAIN_ID=1301

# Verification pacing (--delay 1 stays under typical 5 req/sec limits)
VERIFY_DELAY_SECONDS=1
VERIFY_RETRIES=5

# After deploy (docs/DEPLOYMENT.md)
POOL_MANAGER_ADDRESS=
STRATUM_HOOK_ADDRESS=
EPOCH_SETTLER_ADDRESS=
COVERAGE_MONITOR_ADDRESS=
CURRENCY0=
CURRENCY1=

# ---------------------------------------------------------------------------
# Frontend (Vite forwards NEXT_PUBLIC_* at build time; see frontend/vite.config.ts)
# docs/FRONTEND_UPGRADE_INSTRUCTIONS.md section 5.2
# ---------------------------------------------------------------------------
# Active StratumHook (after the D-1 redeploy this becomes the NEW mined address)
NEXT_PUBLIC_HOOK_ADDRESS=
# Pre-D-1 hook, kept for historical subgraph data
NEXT_PUBLIC_HOOK_LEGACY=
# StratumLens read aggregator (required for single-call dashboard reads)
NEXT_PUBLIC_LENS_ADDRESS=
# StratumZap position router (required for the deposit UI)
NEXT_PUBLIC_ZAP_ADDRESS=
# The Graph Studio HTTP endpoint for the STRATUM subgraph (D-7); empty hides history panels
NEXT_PUBLIC_SUBGRAPH_URL=
# Uniswap v4 PoolManager
NEXT_PUBLIC_POOL_MANAGER=
# Demo pool id (bytes32) and key parameters
NEXT_PUBLIC_DEFAULT_POOL_ID=
NEXT_PUBLIC_DEMO_POOL_FEE=8388608
NEXT_PUBLIC_DEMO_POOL_TICK_SPACING=60
# RPC override (optional)
NEXT_PUBLIC_RPC_URL=
# "true" only after the D-1 hook redeploy is broadcast and confirmed (Phase F gate)
NEXT_PUBLIC_HOOK_V2=
# Admin treasury for the protocol-fee collect UI (optional)
NEXT_PUBLIC_PROTOCOL_FEE_COLLECTOR=
