# STRATUM frontend environment (all optional; sensible Unichain Sepolia defaults are baked in).
# Copy to .env and fill what you need. Never commit secrets; these are public testnet values.

# --- Wallet + history ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# The Graph (Studio) subgraph for the demo pool; empty falls back to on-chain getLogs history.
NEXT_PUBLIC_SUBGRAPH_URL=

# --- Primary chain override (defaults target Unichain Sepolia 1301) ---
# NEXT_PUBLIC_CHAIN_ID=1301
# NEXT_PUBLIC_CHAIN_NAME=Unichain Sepolia
# NEXT_PUBLIC_RPC_URL=https://sepolia.unichain.org
# NEXT_PUBLIC_EXPLORER_NAME=Blockscout
# NEXT_PUBLIC_EXPLORER_URL=https://unichain-sepolia.blockscout.com

# --- Secondary read-only RPC (Feature Labs: Stylus / Chainlink reads, no wallet switch) ---
# NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# NEXT_PUBLIC_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# --- Feature Labs niceties ---
# Documented attested matchHash for the EigenLayer attestation checker (else the lab prompts for one).
# NEXT_PUBLIC_DEMO_MATCH_HASH=

# --- Gas top-up links shown on the deposit/faucet UI ---
# NEXT_PUBLIC_GAS_FAUCET_URL=https://docs.unichain.org/docs/tools/faucets
# NEXT_PUBLIC_BRIDGE_URL=https://testnets.superbridge.app
